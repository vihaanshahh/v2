{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "v2",
  "version": "0.1.0",
  "identifier": "dev.v2.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "v2 — which LLMs can you run",
        "width": 1200,
        "height": 800,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
